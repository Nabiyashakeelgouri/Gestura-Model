# Security
JWT_SECRET=change-this-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,null

# SMTP for account deletion confirmation
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_USE_TLS=true
DELETE_CONFIRM_BASE_URL=http://127.0.0.1:8000/user/delete/confirm
DELETE_TOKEN_EXPIRE_MINUTES=30

# Inference state machine
ACTIVATION_HOLD_FRAMES=6
NO_HAND_COOLDOWN_FRAMES=12
COOLDOWN_SECONDS=1.5
REQUIRE_CHECKMARK_ACTIVATION=false
DYNAMIC_MIN_HAND_FRAMES=12

# MediaPipe hand/face tracking (0.0 - 1.0)
HAND_MAX_NUM=2
HAND_DETECTION_CONFIDENCE=0.55
HAND_TRACKING_CONFIDENCE=0.50
FACE_DETECTION_CONFIDENCE=0.60
FACE_TRACKING_CONFIDENCE=0.50
MEDIAPIPE_MODEL_COMPLEXITY=1
HAND_MIN_SPAN=0.06
ENABLE_LOW_LIGHT_HAND_FALLBACK=true

# Training (optional overrides)
STATIC_EPOCHS=35
STATIC_BATCH_SIZE=32
STATIC_LEARNING_RATE=0.001
STATIC_VAL_SPLIT=0.2
STATIC_EARLY_STOP_PATIENCE=8
DYNAMIC_EPOCHS=40
DYNAMIC_BATCH_SIZE=16
DYNAMIC_LEARNING_RATE=0.001
DYNAMIC_VAL_SPLIT=0.2

# Secure temp handling for uploaded record-mode files
# RECORD_ENCRYPTION_KEY must be a Fernet key:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
RECORD_ENCRYPTION_KEY=
SECURE_TEMP_DIR=
SECURE_DELETE_PASSES=1
